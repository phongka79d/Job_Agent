ENV=development
BACKEND_PORT=8000
FRONTEND_PORT=5173

DATABASE_URL=sqlite+aiosqlite:///./data/job_matching.db
SQLITE_DB_PATH=./data/job_matching.db

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional OpenAI-compatible endpoint override. Leave blank for official OpenAI.
OPENAI_BASE_URL=
# Optional per-use endpoint overrides. These win over OPENAI_BASE_URL when set.
OPENAI_LLM_BASE_URL=
OPENAI_EMBEDDING_BASE_URL=
EMBEDDING_DIMENSION=1536

TAVILY_API_KEY=your-tavily-api-key

MAX_URLS_PER_BATCH=10
MAX_RAW_TEXT_CHARS=20000
MAX_CLEAN_TEXT_CHARS=12000
MAX_RETRY_PER_JOB=1
REQUEST_TIMEOUT_SECONDS=10
MAX_RESPONSE_SIZE_MB=2
